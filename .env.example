# Copy to .env (gitignored) and fill in real values — never commit .env.
# load_config() reads .env automatically; real environment variables win.

# ── API profile (config.api.yaml) — Anthropic + OpenAI ──────
# Only needed when the API profile is selected; the local Ollama profile
# needs no keys at all. The first-run chooser prompts for these and writes
# them here.
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here

# ── Optional overrides (see src/korani/config.py) ───────────
# KORANI_LLM_BASE_URL=...            # global endpoint override
# KORANI_LLM_API_KEY=...             # global endpoint key (rarely needed)
# KORANI_MODEL_SPEC_EXTRACTOR=...    # per-role model override, any role name
